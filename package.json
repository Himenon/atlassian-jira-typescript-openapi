{
  "name": "@himenon/atlassian-jira-typescript-openapi",
  "version": "2.0.0",
  "description": "Implementation of TypeScript generated from argocd OpenAPI",
  "keywords": [
    "OpenAPI",
    "Swagger",
    "atlassian",
    "jira"
  ],
  "homepage": "https://github.com/Himenon/atlassian-jira-typescript-openapi#readme",
  "bugs": {
    "url": "https://github.com/Himenon/atlassian-jira-typescript-openapi/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Himenon",
    "email": "k.himeno314@gmail.com",
    "url": "https://github.com/Himenon"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:Himenon/atlassian-jira-typescript-openapi.git"
  },
  "directories": {
    "lib": "lib"
  },
  "files": [
    "lib",
    "package.json",
    "README.md"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./lib/$cjs/index.js",
  "module": "./lib/$esm/index.js",
  "types": "./lib/$types/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "build:all": "run-s fetch:schemas generate:code",
    "clean": "rimraf dist",
    "fetch:schemas": "node --strip-types ./scripts/fetchSchema.ts",
    "lerna:version:up": "lerna version --yes",
    "generate:code": "node --strip-types ./scripts/generateCode.ts",
    "release:github:registry": "pnpm publish --registry https://npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}",
    "release:npm:registry": "pnpm publish",
    "test": "run-s validate",
    "lint": "oxlint .",
    "format": "oxfmt",
    "type-check": "tsc --noEmit",
    "validate": "oxfmt --check"
  },
  "devDependencies": {
    "@himenon/openapi-typescript-code-generator": "2.0.6",
    "@swc/core": "^1.15.33",
    "@types/node": "25.7.0",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "conventional-changelog-angular-all": "1.7.0",
    "cross-env": "^10.1.0",
    "execa": "^9.6.1",
    "lefthook": "^2.1.6",
    "lerna": "9.0.7",
    "node-fetch": "^3.3.2",
    "npm-run-all": "4.1.5",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "rimraf": "^6.1.3",
    "swagger2openapi": "^7.0.8",
    "tsup": "^8.5.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.1.2"
}
